# ============================================================
# MindNest configuration — copy to ".env" and edit as needed.
#   cp .env.example .env
# Every value has a sane default, so an empty .env still works.
# ============================================================

# ---- App ----
APP_NAME=MindNest
ENV=development           # development | production
DEBUG=true

# ---- Security / JWT ----
# CHANGE THIS in production. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-insecure-change-me-please-0000000000000000000000
ACCESS_TOKEN_EXPIRE_MINUTES=10080      # 7 days

# ---- Database ----
# SQLite for local MVP. To upgrade to Postgres just swap the URL:
#   DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/mindnest
DATABASE_URL=sqlite+aiosqlite:///./mindnest.db

# ---- CORS (comma separated, "*" for all) ----
CORS_ORIGINS=*

# ---- Adaptive questionnaire engine ----
MIN_QUESTIONS=6
MAX_QUESTIONS=14
CONFIDENCE_TARGET=0.78     # stop early once key dimensions are this confident

# ---- Optional local AI layers (need requirements-ai.txt) ----
ENABLE_TRANSFORMER_EMOTION=true   # j-hartmann/emotion-english-distilroberta-base
ENABLE_EMBEDDINGS=true            # sentence-transformers/all-MiniLM-L6-v2
EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- Optional local LLM via Ollama ----
ENABLE_LLM=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=tinyllama            # or phi, phi3, mistral, llama3.2 ...
OLLAMA_TIMEOUT=45                 # seconds
